APP_NAME=OmniFlow Business Sync Demo
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_PATH=./data/omniflow.db

DEFAULT_PROVIDER=mock
PROVIDER_FALLBACK_ORDER=mock,openai,anthropic,gemini

REQUEST_TIMEOUT_SECONDS=20
MAX_RETRIES=2

ENABLE_CONNECTORS=false
ENABLE_GITHUB_CONNECTOR=false
ENABLE_SLACK_CONNECTOR=false
ENABLE_SHEETS_CONNECTOR=false
ENABLE_WEBHOOK_CONNECTOR=false

N8N_WEBHOOK_URL=
CUSTOM_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
GITHUB_API_URL=
GITHUB_TOKEN=
GITHUB_REPO=
SHEETS_WEBHOOK_URL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
